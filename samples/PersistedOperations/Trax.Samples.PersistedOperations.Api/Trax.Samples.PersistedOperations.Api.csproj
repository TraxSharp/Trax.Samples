<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowMissingPrunePackageData>true</AllowMissingPrunePackageData>
    <!-- Required by Trax.Dashboard. The dashboard package cannot propagate
         this transitively because the Razor SDK overwrites its NuGet build
         props with static-asset imports during pack. Every host that calls
         UseTraxDashboard() must set this themselves. Without it, the build
         omits _framework/blazor.web.js and the Blazor Server circuit never
         establishes (the page renders but every button click is a no-op). -->
    <RequiresAspNetWebAssets>true</RequiresAspNetWebAssets>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Trax.Samples.PersistedOperations\Trax.Samples.PersistedOperations.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Trax.Api" />
    <PackageReference Include="Trax.Api.GraphQL" />
    <PackageReference Include="Trax.Api.GraphQL.PersistedOperations" />
    <PackageReference Include="Trax.Dashboard" />
    <PackageReference Include="Trax.Scheduler" />
    <PackageReference Include="Trax.Effect.Provider.Json" />
  </ItemGroup>
</Project>
